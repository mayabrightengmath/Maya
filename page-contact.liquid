<section style="background:white;padding:72px 24px 56px;border-bottom:1px solid #F0EDE8;text-align:center;">
  <div class="be-container--narrow">
    <div class="be-section-tag">Get in Touch</div>
    <h1 class="be-section-title" style="margin-top:16px;">ติดต่อเรา</h1>
    <p style="font-size:17px;color:#78716C;line-height:1.75;margin-top:12px;">Contact Us — ยินดีตอบทุกคำถาม ทุกวัน 9:00–21:00 น.</p>
  </div>
</section>

<section style="padding:72px 24px 88px;">
  <div class="be-container" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:40px;align-items:start;">

    <!-- Channels -->
    <div>
      <h2 style="font-size:22px;font-weight:800;color:#1C1917;margin-bottom:8px;">ช่องทางติดต่อ</h2>
      <p style="font-size:15px;color:#78716C;margin-bottom:28px;line-height:1.7;">เลือกช่องทางที่สะดวกสำหรับคุณ เราตอบเร็วที่สุดผ่าน Line</p>
      <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:36px;">
        {%- if settings.social_line != blank -%}
        <a href="https://line.me/ti/p/{{ settings.social_line }}" style="display:flex;align-items:center;gap:16px;background:white;border-radius:16px;padding:18px 20px;border:1.5px solid #F0EDE8;text-decoration:none;transition:all 0.2s;" target="_blank" rel="noopener">
          <div style="width:48px;height:48px;background:#F0FDF4;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">💚</div>
          <div style="flex:1;"><div style="font-size:15px;font-weight:700;color:#1C1917;margin-bottom:2px;">LINE Official</div><div style="font-size:13px;color:#78716C;">{{ settings.social_line }}</div></div>
          <span style="font-size:12px;font-weight:600;padding:5px 10px;border-radius:100px;background:#F0FDF4;color:#16A34A;">Fastest</span>
        </a>
        {%- endif -%}
        {%- if settings.social_facebook != blank -%}
        <a href="{{ settings.social_facebook }}" style="display:flex;align-items:center;gap:16px;background:white;border-radius:16px;padding:18px 20px;border:1.5px solid #F0EDE8;text-decoration:none;transition:all 0.2s;" target="_blank" rel="noopener">
          <div style="width:48px;height:48px;background:#EFF6FF;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">📘</div>
          <div style="flex:1;"><div style="font-size:15px;font-weight:700;color:#1C1917;margin-bottom:2px;">Facebook</div><div style="font-size:13px;color:#78716C;">Bright ENGMATH</div></div>
          <span style="font-size:12px;font-weight:600;padding:5px 10px;border-radius:100px;background:#EFF6FF;color:#2563EB;">Active</span>
        </a>
        {%- endif -%}
        {%- if settings.contact_email != blank -%}
        <a href="mailto:{{ settings.contact_email }}" style="display:flex;align-items:center;gap:16px;background:white;border-radius:16px;padding:18px 20px;border:1.5px solid #F0EDE8;text-decoration:none;transition:all 0.2s;">
          <div style="width:48px;height:48px;background:#FFF3E8;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">📧</div>
          <div style="flex:1;"><div style="font-size:15px;font-weight:700;color:#1C1917;margin-bottom:2px;">Email</div><div style="font-size:13px;color:#78716C;">{{ settings.contact_email }}</div></div>
          <span style="font-size:12px;font-weight:600;padding:5px 10px;border-radius:100px;background:#FFF3E8;color:#F97316;">Official</span>
        </a>
        {%- endif -%}
      </div>
      <div style="background:linear-gradient(135deg,#FFF3E8,#FFE4C4);border-radius:16px;padding:22px 24px;border:1px solid #FED7AA;">
        <div style="font-size:13px;font-weight:700;color:#F97316;letter-spacing:1px;text-transform:uppercase;margin-bottom:12px;">Response Hours</div>
        <div style="display:flex;justify-content:space-between;margin-bottom:8px;"><span style="font-size:14px;color:#78716C;">Monday – Friday</span><span style="font-size:14px;font-weight:700;color:#1C1917;">9:00 – 21:00</span></div>
        <div style="display:flex;justify-content:space-between;"><span style="font-size:14px;color:#78716C;">Saturday – Sunday</span><span style="font-size:14px;font-weight:700;color:#1C1917;">9:00 – 18:00</span></div>
        <div style="margin-top:12px;padding-top:12px;border-top:1px solid rgba(249,115,22,0.2);font-size:13px;color:#92400E;">⚡ ตอบกลับเฉลี่ยภายใน 1–2 ชั่วโมง</div>
      </div>
    </div>

    <!-- Contact Form -->
    <div style="background:white;border-radius:20px;padding:36px;border:1px solid #F0EDE8;">
      <h2 style="font-size:20px;font-weight:800;color:#1C1917;margin-bottom:6px;">ส่งข้อความหาเรา</h2>
      <p style="font-size:14px;color:#78716C;margin-bottom:28px;">Send us a message and we'll reply within a few hours</p>

      {%- form 'contact', data-contact-form: '' -%}
        {%- if form.posted_successfully? -%}
          <div style="text-align:center;padding:48px 24px;">
            <div style="font-size:56px;margin-bottom:16px;">✅</div>
            <h3 style="font-size:22px;font-weight:800;color:#1C1917;margin-bottom:10px;">ส่งข้อความสำเร็จแล้ว!</h3>
            <p style="font-size:15px;color:#78716C;line-height:1.75;">ขอบคุณที่ติดต่อมานะคะ เราจะรีบตอบกลับโดยเร็วที่สุดค่ะ</p>
          </div>
        {%- else -%}
          <div class="form-grid-2">
            <div class="form-group">
              <label class="form-label" for="ContactForm-name">ชื่อ (Name) *</label>
              <input class="form-input" type="text" id="ContactForm-name" name="contact[name]" value="{%- if form.name -%}{{ form.name }}{%- elsif customer -%}{{ customer.name }}{%- endif -%}" placeholder="ชื่อของคุณ" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="ContactForm-email">อีเมล (Email) *</label>
              <input class="form-input" type="email" id="ContactForm-email" name="contact[email]" value="{%- if form.email -%}{{ form.email }}{%- elsif customer -%}{{ customer.email }}{%- endif -%}" placeholder="email@example.com" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="ContactForm-subject">เรื่องที่ต้องการติดต่อ</label>
            <select class="form-select" id="ContactForm-subject" name="contact[subject]">
              <option>ปัญหาการดาวน์โหลด</option>
              <option>ถามเกี่ยวกับสินค้า</option>
              <option>ปัญหาการชำระเงิน</option>
              <option>ต้องการใบอนุญาตพิเศษ</option>
              <option>รายงานปัญหาไฟล์</option>
              <option>อื่นๆ</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="ContactForm-message">ข้อความ (Message) *</label>
            <textarea class="form-textarea" id="ContactForm-message" name="contact[body]" rows="4" placeholder="เขียนรายละเอียดที่ต้องการสอบถาม..." required>{{- form.body -}}</textarea>
          </div>
          <button type="submit" class="btn btn--primary btn--full" data-submit-btn>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
            ส่งข้อความ
          </button>
          <p style="font-size:12px;color:#A8A29E;text-align:center;margin-top:12px;">ตอบกลับเฉลี่ยภายใน 1–2 ชั่วโมง ในเวลาทำการ</p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Page",
  "settings": [],
  "presets": [{ "name": "Contact Page" }]
}
{% endschema %}
