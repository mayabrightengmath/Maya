<section class="hero">
  <div class="be-container">
    <div class="hero__grid">

      <!-- Left: text -->
      <div data-animate>
        <div class="hero__badge">
          <span class="hero__badge-star">★ {{ section.settings.rating }}</span>
          <span class="hero__badge-text">{{ section.settings.trust_text }}</span>
        </div>
        <h1 class="hero__title">
          {{ section.settings.headline | split: '|' | first }}
          <span>{{ section.settings.headline | split: '|' | last }}</span>
        </h1>
        <p class="hero__subtitle">{{ section.settings.subheadline }}</p>
        <div class="hero__ctas">
          <a href="{{ section.settings.btn_primary_link }}" class="btn btn--primary btn--lg">
            {{ section.settings.btn_primary_label }}
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </a>
          <a href="{{ section.settings.btn_secondary_link }}" class="btn btn--secondary btn--lg">
            {{ section.settings.btn_secondary_label }}
          </a>
        </div>
        <div class="hero__trust">
          <div class="hero__trust-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2.5" stroke-linecap="round"><path d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            Instant Download
          </div>
          <div class="hero__trust-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2.5" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
            PDF Files
          </div>
          <div class="hero__trust-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2.5" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            Secure Payment
          </div>
        </div>
      </div>

      <!-- Right: illustration -->
      <div class="hero__illustration">
        <div class="hero__blob"></div>
        <div class="hero__card-wrap">
          <div class="hero__card-shadow1"></div>
          <div class="hero__card-shadow2"></div>
          <div class="hero__card">
            <div class="hero__card-header">
              <div class="hero__card-badge">MATH WORKSHEET</div>
              <div class="hero__card-title">Addition &amp;<br>Subtraction</div>
              <div class="hero__card-meta">Grade 1–3 · 50 Pages · PDF</div>
            </div>
            <div class="hero__card-body">
              <div class="hero__card-row">
                <span>5 + 3 = ____</span>
                <span class="tag tag--orange" style="font-size:9px;">Easy</span>
              </div>
              <div class="hero__card-row">
                <span>12 − 7 = ____</span>
                <span class="tag tag--orange" style="font-size:9px;">Easy</span>
              </div>
              <div class="hero__card-row">
                <span>25 + 18 = ____</span>
                <span class="tag tag--blue" style="font-size:9px;">Med</span>
              </div>
              <div class="hero__card-score">Score: _____ / 10 ★</div>
            </div>
          </div>
        </div>
        <div class="hero__float-card hero__float-card--bottom">
          <div class="hero__float-icon">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2.5" stroke-linecap="round"><path d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <div>
            <div style="font-size:11px;font-weight:700;color:#1C1917;line-height:1.2;">Instant Download</div>
            <div style="font-size:10px;color:#78716C;">After payment</div>
          </div>
        </div>
        <div class="hero__float-card hero__float-card--top">
          <div style="font-size:12px;font-weight:800;color:#1C1917;margin-bottom:2px;">★★★★★ 5.0</div>
          <div style="font-size:10px;color:#78716C;">1,000+ customers</div>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "headline", "label": "Headline (use | to split orange part)", "default": "Digital Worksheets & E-books for |Bright Young Learners" },
    { "type": "textarea", "id": "subheadline", "label": "Subheadline", "default": "สื่อการเรียนรู้ภาษาอังกฤษและคณิตศาสตร์ พร้อมดาวน์โหลด ใช้งานง่าย เหมาะสำหรับเด็ก ผู้ปกครอง และคุณครู" },
    { "type": "text", "id": "btn_primary_label", "label": "Primary button label", "default": "Shop Digital Files" },
    { "type": "url", "id": "btn_primary_link", "label": "Primary button URL" },
    { "type": "text", "id": "btn_secondary_label", "label": "Secondary button label", "default": "View Free Samples" },
    { "type": "url", "id": "btn_secondary_link", "label": "Secondary button URL" },
    { "type": "text", "id": "rating", "label": "Rating text", "default": "5.0" },
    { "type": "text", "id": "trust_text", "label": "Trust badge text", "default": "Trusted by 1,000+ parents & teachers" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
