<section class="be-section--lg free-samples-cta" id="freebies">
  <div class="be-container--narrow" style="text-align:center;">
    <div class="be-section-tag" style="background:white;box-shadow:0 2px 8px rgba(249,115,22,0.15);">100% Free</div>
    <h2 class="be-section-title" style="margin-top:16px;">{{ section.settings.title }}</h2>
    <p style="font-size:17px;color:#78716C;margin-bottom:10px;line-height:1.7;margin-top:14px;">{{ section.settings.subtitle }}</p>
    <p style="font-size:15px;color:#A8A29E;margin-bottom:44px;line-height:1.7;">{{ section.settings.description }}</p>

    <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:44px;">
      {%- for block in section.blocks -%}
      <div class="free-samples-cta__sample-card" {{ block.shopify_attributes }}>
        <div class="free-samples-cta__sample-icon" style="background:{{ block.settings.icon_bg }};">
          {%- render 'icon', name: block.settings.icon, color: block.settings.icon_color, size: 20 -%}
        </div>
        <div style="font-size:12px;font-weight:700;color:#1C1917;line-height:1.3;">{{ block.settings.title }}</div>
        <div style="font-size:11px;color:#A8A29E;margin-top:3px;">{{ block.settings.grade }}</div>
      </div>
      {%- endfor -%}
    </div>

    <a href="{{ section.settings.btn_link }}" class="btn btn--primary btn--lg">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 16v1a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
      {{ section.settings.btn_label }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Free Samples CTA",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Try Free Learning Materials" },
    { "type": "text", "id": "subtitle", "label": "Thai subtitle", "default": "ดาวน์โหลดตัวอย่างฟรีก่อนตัดสินใจซื้อ" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "No email required. Download instantly and see the quality for yourself before you buy." },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Download Free Samples" },
    { "type": "url", "id": "btn_link", "label": "Button URL" }
  ],
  "blocks": [
    {
      "type": "sample",
      "name": "Sample card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Math Starter" },
        { "type": "text", "id": "grade", "label": "Grade", "default": "Grade 1" },
        { "type": "color", "id": "icon_bg", "label": "Icon background", "default": "#FFF3E8" },
        { "type": "color", "id": "icon_color", "label": "Icon color", "default": "#F97316" },
        { "type": "select", "id": "icon", "label": "Icon", "default": "math", "options": [
          { "value": "math", "label": "Math" },
          { "value": "book", "label": "Book" },
          { "value": "clipboard", "label": "Clipboard" }
        ]}
      ]
    }
  ],
  "presets": [
    {
      "name": "Free Samples CTA",
      "blocks": [
        { "type": "sample", "settings": { "title": "Math Starter", "grade": "Grade 1", "icon_bg": "#FFF3E8", "icon_color": "#F97316", "icon": "math" } },
        { "type": "sample", "settings": { "title": "Phonics ABC", "grade": "KG", "icon_bg": "#EFF6FF", "icon_color": "#2563EB", "icon": "book" } },
        { "type": "sample", "settings": { "title": "Quiz Prep", "grade": "Grade 3", "icon_bg": "#F0FDF4", "icon_color": "#16A34A", "icon": "clipboard" } }
      ]
    }
  ]
}
{% endschema %}
